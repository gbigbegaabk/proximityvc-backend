# ================================
# ProximityVC Backend Environment
# ================================

# Secret key - must match your plugin's config.yml api-key
API_KEY=change-this-to-a-secret-key

# Port the backend runs on
PORT=3000

# Your Minecraft server IP and port (for online detection)
MC_SERVER_IP=your-minecraft-server.com
MC_SERVER_PORT=25565

# Voice proximity rules (in blocks)
RANGE_FULL=10
RANGE_MEDIUM=30
RANGE_LOW=50

# Volume levels (0.0 to 1.0)
VOL_FULL=1.0
VOL_MEDIUM=0.6
VOL_LOW=0.3
